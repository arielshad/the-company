{
  "inputSchema": {
    "type": "object",
    "required": ["name", "company", "email", "source"],
    "properties": {
      "name": { "type": "string" },
      "company": { "type": "string" },
      "email": { "type": "string", "format": "email" },
      "source": { "type": "string" },
      "notes": { "type": "string" }
    }
  },
  "outputSchema": {
    "type": "object",
    "required": ["decision", "score", "confidence", "rationale", "citations"],
    "properties": {
      "decision": { "enum": ["sales_ready", "nurture", "disqualify"] },
      "score": { "type": "number", "minimum": 0, "maximum": 1 },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "rationale": { "type": "string" },
      "citations": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["sourceRef", "quote"],
          "properties": {
            "sourceRef": { "type": "string" },
            "quote": { "type": "string" }
          }
        }
      }
    }
  },
  "requiredTools": [
    { "tool": "brain.search", "scopes": ["brain:reader"] },
    { "tool": "crm.update", "scopes": ["connector:crm#user"] },
    { "tool": "notify.slack", "scopes": ["connector:slack#user"] }
  ]
}
