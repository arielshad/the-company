{
  "realm": "companyos",
  "enabled": true,
  "displayName": "CompanyOS",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Org owner — full control" },
      { "name": "admin", "description": "Administer org, connectors, permissions" },
      { "name": "builder", "description": "Build workflows and skills" },
      { "name": "member", "description": "Use the brain and run skills" },
      { "name": "auditor", "description": "Read-only audit and compliance access" },
      { "name": "agent", "description": "Non-human principal (managed agent)" }
    ]
  },
  "groups": [
    { "name": "leadership" },
    { "name": "ops" },
    { "name": "engineering" },
    { "name": "sales" },
    { "name": "support" }
  ],
  "clients": [
    {
      "clientId": "companyos-web",
      "name": "CompanyOS Web (frontend)",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://app.companyos.example/*", "http://localhost:3000/*"],
      "webOrigins": ["+"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "companyos-gateway",
      "name": "CompanyOS Gateway (MCP / BFF)",
      "publicClient": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "secret": "REPLACED_BY_SEALED_SECRET",
      "redirectUris": ["https://app.companyos.example/*"],
      "comment": "confidential client; secret injected from SealedSecret keycloak-client-secrets, never committed in plaintext"
    },
    {
      "clientId": "companyos-services",
      "name": "CompanyOS service-to-service",
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "REPLACED_BY_SEALED_SECRET",
      "comment": "client-credentials for inter-service tokens (FR-1.5)"
    }
  ]
}
